rules_version = '2';

// Aturan Phase 1+8+10 — salin ke Firebase Console → Firestore → Rules → Publish.
service cloud.firestore {
  match /databases/{database}/documents {

    // True bila user login = guru pemilik kelas `kode` (dipakai kontrol siswa
    // & pengumuman). kode harus string valid (siswa tanpa kelas → false).
    function guruPemilikKelas(kode) {
      return request.auth != null
        && kode is string
        && exists(/databases/$(database)/documents/kelas/$(kode))
        && get(/databases/$(database)/documents/kelas/$(kode)).data.guruId == request.auth.uid;
    }

    // Profil user: SEMUA user login boleh membaca (Leaderboard Phase 8 —
    // profil hanya berisi nama depan + avatar kartun, privasi tetap aman);
    // menulis hanya pemiliknya.
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;

      // Guru boleh mengelola SISWA di kelas miliknya (Teacher Dashboard):
      // keluarkan (kelasId → null) atau reset progres. Dibatasi field tsb
      // saja supaya guru tak bisa mengubah identitas/role siswa.
      allow update: if resource.data.role == "siswa"
        && guruPemilikKelas(resource.data.kelasId)
        && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(["kelasId", "progress", "poin", "level", "koleksi"]);
    }

    // Pengumuman kelas (Teacher Dashboard): semua user login boleh membaca
    // (siswa melihatnya di Kelasku); guru hanya membuat/menghapus pengumuman
    // untuk kelas MILIKNYA sendiri.
    match /pengumuman/{pengumumanId} {
      allow read: if request.auth != null;
      allow create: if request.resource.data.guruId == request.auth.uid
        && guruPemilikKelas(request.resource.data.kelasId);
      allow delete: if request.auth != null
        && resource.data.guruId == request.auth.uid;
    }

    // Kode kelas: semua user login boleh membaca (validasi join siswa +
    // lookup guruId untuk soal). Guru membuat/mengubah kelas MILIKNYA sendiri
    // (Phase 10) — guruId di dokumen harus uid pembuat.
    match /kelas/{kodeKelas} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.guruId == request.auth.uid;
      allow update, delete: if request.auth != null
        && resource.data.guruId == request.auth.uid;
    }

    // Soal buatan guru (Phase 10, skema §6 sumber:"guru"): siswa perlu
    // membacanya untuk Kuis; guru hanya bisa menulis soal miliknya sendiri.
    match /soalGuru/{soalId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.guruId == request.auth.uid;
      allow update, delete: if request.auth != null
        && resource.data.guruId == request.auth.uid;
    }

    // Rekor Mode Tanpa Batas (level 10 Kuis & Isi Piringku): satu dokumen
    // per (game, siswa) — id "game_uid" — berisi skor terbaik saja. Semua
    // user login boleh membaca (papan rekor); menulis hanya rekor miliknya
    // sendiri, dan id dokumen wajib cocok dengan isinya (anti menimpa rekor
    // siswa lain / menulis atas nama orang lain).
    match /rekorEndless/{rekorId} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null
        && request.resource.data.userId == request.auth.uid
        && rekorId == request.resource.data.game + '_' + request.auth.uid;
    }
  }
}
