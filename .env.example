# === Anakara — Environment Variables ===
# Salin file ini jadi ".env" lalu isi nilainya. JANGAN commit ".env" ke git.
#
# API key Google Gemini (untuk image generation asset).
# Ambil di: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# (opsional) Model image generation default.
# - gemini-2.5-flash-image  -> "Nano Banana", bagus untuk konsistensi karakter + pakai gambar referensi
# - imagen-4.0-generate-001 -> Imagen 4, text-to-image kualitas tinggi (tanpa referensi)
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image

# === Firebase (web app) — untuk aplikasi Next.js ===
# Salin bagian ini ke ".env.local" (dibaca Next.js). Nilai dari
# Firebase Console -> Project settings -> Your apps -> SDK setup (config).
# Prefix NEXT_PUBLIC_ = ikut terkirim ke browser (memang publik oleh desain
# Firebase; keamanan data diatur lewat Security Rules). Diisi saat Phase 1.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# URL Realtime Database — untuk Team Battle 2v2 (Phase 6).
# Firebase Console -> Build -> Realtime Database -> Create Database (pilih region
# terdekat, mis. Singapore) -> salin URL "https://...firebasedatabase.app".
# Setelah itu publish rules dari file database.rules.json.
NEXT_PUBLIC_FIREBASE_DATABASE_URL=
